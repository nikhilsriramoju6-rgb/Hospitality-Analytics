      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0hgckny1dbgscd19ljqm70mkhour].[pcto:usr:Calculation_1547038423502863:qk]&quot;' value='Realisation%' />
          <alias key='&quot;[federated.0hgckny1dbgscd19ljqm70mkhour].[usr:Calculation_1547038420664327:qk]&quot;' value='Cancelled Bookings ' />
        </aliases>
      </column>
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1547038422650892] / TOTAL([Calculation_1547038422650892])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue ' datatype='integer' name='[Calculation_1547038419202048]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_realized])' />
      </column>
      <column caption='Total Bookings ' datatype='integer' name='[Calculation_1547038419333121]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([booking_id])' />
      </column>
      <column caption='Total Capacity' datatype='integer' name='[Calculation_1547038419464194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([capacity])' />
      </column>
      <column caption='Total Successful Bookings' datatype='integer' name='[Calculation_1547038419566595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([successful_bookings])' />
      </column>
      <column caption='Occupancy %' datatype='real' name='[Calculation_1547038419910660]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([successful_bookings])/SUM([capacity])' />
      </column>
      <column caption='Avarage Ratings' datatype='real' name='[Calculation_1547038420160517]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([ratings_given])' />
      </column>
      <column caption='No.of days' datatype='integer' name='[Calculation_1547038420279302]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,MIN([date]),MAX([date]))+1' />
      </column>
      <column caption='Total Cancelled Bookings ' datatype='integer' name='[Calculation_1547038420664327]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;Cancelled&quot; then 1 else 0 end)' />
      </column>
      <column caption='Total No show Bookings ' datatype='integer' name='[Calculation_1547038421102600]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;NO Show&quot; then 1 else 0 end)' />
      </column>
      <column caption='Total Checked Out' datatype='integer' name='[Calculation_1547038421434377]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;Checked Out&quot; then 1 else 0 end)' />
      </column>
      <column caption='Cancellation %' datatype='real' name='[Calculation_1547038422200331]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;Cancelled&quot; then 1 else 0 end)/&#13;&#10;COUNT([booking_id])' />
      </column>
      <column caption='No Show Rate %' datatype='real' name='[Calculation_1547038422650892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;No Show&quot; then 1 else 0 end)/&#13;&#10;COUNT([booking_id])' />
      </column>
      <column caption='ADR' datatype='real' name='[Calculation_1547038423302158]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_realized])/COUNT([booking_id])' />
      </column>
      <column caption='Realisation%' datatype='real' name='[Calculation_1547038423502863]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1-([Calculation_1547038422200331]+[Calculation_1547038422650892])' />
      </column>
      <column caption='RevPAR' datatype='real' name='[Calculation_1547038423785488]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue_realized])/SUM([capacity])' />
      </column>
      <column caption='DBRN' datatype='real' name='[Calculation_1547038423986193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([booking_id])/(DATEDIFF(&apos;day&apos;,MIN([date]),MAX([date]))+1)' />
      </column>
      <column caption='DSRN' datatype='real' name='[Calculation_1547038424428562]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([capacity])/(DATEDIFF(&apos;day&apos;,MIN([date]),MAX([date]))+1)' />
      </column>
      <column caption='DURN' datatype='real' name='[Calculation_1547038425042963]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;Checked Out&quot; then 1 else 0 end)/&#13;&#10;(DATEDIFF(&apos;day&apos;,MIN([date]),MAX([date]))+1)' />
      </column>
