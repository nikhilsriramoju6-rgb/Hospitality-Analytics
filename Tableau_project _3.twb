            </column>
            <column caption='Total Bookings ' datatype='integer' name='[Calculation_1547038419333121]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([booking_id])' />
            </column>
            <column caption='Cancellation %' datatype='real' name='[Calculation_1547038422200331]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;Cancelled&quot; then 1 else 0 end)/&#13;&#10;COUNT([booking_id])' />
            </column>
            <column caption='No Show Rate %' datatype='real' name='[Calculation_1547038422650892]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [booking_status] = &quot;No Show&quot; then 1 else 0 end)/&#13;&#10;COUNT([booking_id])' />
            </column>
            <column caption='ADR' datatype='real' name='[Calculation_1547038423302158]' role='measure' type='quantitative'>
